{
  "name": "@agentledger/suil",
  "version": "1.0.0",
  "description": "Smart Universal Intelligence Layer - 22,500x faster AI processing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "demo": "npm run build && node dist/demo/integrated-suil-demo.js",
    "demo:dev": "ts-node demo/integrated-suil-demo.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "prepare": "npm run build",
    "benchmark": "npm run build && node dist/benchmark/performance-benchmark.js"
  },
  "keywords": [
    "ai",
    "intelligence",
    "performance",
    "optimization",
    "suil",
    "agentledger",
    "typescript"
  ],
  "author": "AgentLedger Team",
  "license": "MIT",
  "dependencies": {
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bigale/agentledger.git",
    "directory": "src/suil"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ]
}